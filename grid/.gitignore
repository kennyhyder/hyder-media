# Dependencies
node_modules/

# Build output / cache (regenerated by `next build`)
.next/
out/
*.tsbuildinfo

# Local env / secrets — NEVER commit
.env.local
.env*.local

# OS / iCloud cruft
.DS_Store
*.icloud

# NOTE: src/, public/, all config files, package.json, and src/data/ ARE tracked
# on purpose. They were previously ignored (static-export era) which let iCloud
# evict the only local copies of the source. The source now lives in git —
# do not re-ignore them.
